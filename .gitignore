venv/
__pycache__/
*.pyc
.DS_Store
.ipynb_checkpoints/
.env

# Backup/snapshot JSON files (clutter — regenerated on each iteration)
data/features/*.bak.json
data/features/*.pre_*.json
data/features/*.reasoning_bak.json
data/features/*.section_*.json
data/features/*.fix_everything_bak.json

# Raw source data (big, regenerated by scrapers)
data/raw/

# ML pickle models (big, regenerated by training)
models/*.pkl

# Processed intermediate files — but keep the final artifacts the
# dashboard serves so the cloud deploy works without re-running the
# entire pipeline.
data/processed/*
# Legacy benchmark outputs (kept for Benchmark mode)
!data/processed/monte_carlo_2026_v12.csv
!data/processed/model_reasoning_2026.json
!data/processed/predictions_2026.csv
!data/processed/prospects_2026_enriched.csv
!data/processed/team_context_2026_enriched.csv
!data/processed/team_context_2026.csv
!data/processed/team_needs_2026.csv
!data/processed/gm_positional_allocation.csv
# Independent pipeline outputs (the product default — MUST ship to server)
!data/processed/monte_carlo_2026_independent.csv
!data/processed/model_reasoning_2026_independent.json
!data/processed/predictions_2026_independent.csv
!data/processed/predictions_2026_independent_picks.csv

# Frontend node_modules / build artifacts (build is re-run on deploy)
frontend/node_modules/
frontend/dist/

# Per-run debug/temp
data/processed/_stage2_*.log
data/processed/_stage2_*.out
data/processed/_last_sim*.txt
